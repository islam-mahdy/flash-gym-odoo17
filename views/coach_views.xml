<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gym_coach_view" model="ir.ui.view">
        <field name="name">gym.coach.tree</field>
        <field name="model">gym.coach</field>
        <field name="arch" type="xml">
            <tree string="Coaches">
                <field name="coach_code"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="hire_date"/>
                <field name="employee_type" widget="badge"
                       decoration-success="employee_type == 'full_time'"
                       decoration-info="employee_type == 'part_time'"
                       decoration-warning="employee_type == 'freelance'" />
            </tree>
        </field>
    </record>

    <record id="view_gym_coach_form" model="ir.ui.view">
        <field name="name">gym.coach.form</field>
        <field name="model">gym.coach</field>
        <field name="arch" type="xml">
            <form string="coach">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Full Name"/></h1>
                        <h2><field name="coach_code" readonly="1"/></h2>
                    </div>
                    <group>
                        <group string="Coach Info">
                            <field name="employee_type"/>
                            <field name="hire_date"/>
                            <field name="years_experience"/>
                            <field name="specialization_ids" widget="many2many_tags"/>
                            <field name="certification_ids" widget="many2many_tags"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group>
                        <field name="bio" placeholder="Add any info about bio here..."/>
                    </group>


                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_gym_coach" model="ir.actions.act_window">
        <field name="name">Coaches</field>
        <field name="res_model">gym.coach</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>