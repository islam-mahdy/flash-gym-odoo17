<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gym_payment_tree" model="ir.ui.view">
        <field name="name">gym.payment.tree</field>
        <field name="model">gym.payment</field>
        <field name="arch" type="xml">
            <tree string="Payments">
                <field name="name"/>
                <field name="membership_id"/>
                <field name="member_id"/>
                <field name="payment_date"/>
                <field name="ref"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'refunded'"/>
            </tree>
        </field>
    </record>

    <record id="view_gym_payment_form" model="ir.ui.view">
        <field name="name">gym.payment.form</field>
        <field name="model">gym.payment</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <header>
                    <button name="action_confirm" string="Confirm Payment" type="object"
                            class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_refund" string="Refund Payment" type="object"
                            class="btn-danger" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,refunded"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" placeholder="payment Method Name"/>
                        </h1>

                        <label for="membership_id" />
                        <h2>
                            <field name="membership_id" placeholder="Select Membership"/>
                        </h2>
                    </div>
                    <group>
                        <group>
<!--                            <field name="class_id" options="{'no_create': True}"/>-->
                            <field name="member_id"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="payment_date"/>
                            <field name="payment_method"/>
                            <field name="ref"/>
                            <field name="state"/>
                        </group>
                        <group string="Notes">
                            <field name="notes" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_gym_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">gym.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first gym class Payment!
            </p>
        </field>
    </record>

</odoo>