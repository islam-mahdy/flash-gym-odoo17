<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_expire_memberships" model="ir.cron">
        <field name="name">Flash GYM: Expire Memberships Daily</field>
        <field name="model_id" ref="model_gym_membership"/>
        <field name="state">code</field>
        <field name="code">model.action_check_expired_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

</odoo>